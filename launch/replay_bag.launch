<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="mode" default="odom" doc="odom, odom_imu ou odom_imu_gps"/>
  <arg name="bag" default="$(find localiza_o_robotica)/bags/husky_trajectory.bag"/>
  <arg name="rate" default="1.0"/>
  <arg name="output_dir" default="$(find localiza_o_robotica)/results"/>

  <param name="/use_sim_time" value="true"/>

  <include file="$(find localiza_o_robotica)/launch/localization.launch">
    <arg name="mode" value="$(arg mode)"/>
    <arg name="wheel_odom_topic" value="/wheel/odom"/>
    <arg name="imu_topic" value="/imu/data"/>
    <arg name="fix_topic" value="/fix"/>
    <arg name="publish_gt" value="false"/>
    <arg name="record_metrics" value="true"/>
    <arg name="output_dir" value="$(arg output_dir)"/>
  </include>

  <node pkg="rosbag" type="play" name="play_trajectory" output="screen" required="true"
        args="--clock --delay=2.0 --rate=$(arg rate) $(arg bag)"/>
</launch>
