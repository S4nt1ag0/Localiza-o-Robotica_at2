<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="mode" default="odom" doc="odom, odom_imu ou odom_imu_gps"/>
  <arg name="wheel_odom_topic" default="/husky_velocity_controller/odom"/>
  <arg name="imu_topic" default="/imu/data"/>
  <arg name="fix_topic" default="/navsat/fix"/>
  <arg name="model_name" default="husky"/>
  <arg name="publish_gt" default="true"/>
  <arg name="record_metrics" default="true"/>
  <arg name="output_dir" default="$(find localiza_o_robotica)/results"/>
  <arg name="align_gt_origin" default="false"/>
  <arg name="gt_offset_x" default="0.0"/>
  <arg name="gt_offset_y" default="0.0"/>

  <group if="$(eval arg(&quot;wheel_odom_topic&quot;) != &quot;/wheel/odom&quot;)">
    <node pkg="topic_tools" type="relay" name="relay_wheel_odom"
          args="$(arg wheel_odom_topic) /wheel/odom"/>
  </group>

  <group if="$(eval arg(&quot;imu_topic&quot;) != &quot;/imu/data&quot;)">
    <node pkg="topic_tools" type="relay" name="relay_imu"
          args="$(arg imu_topic) /imu/data"/>
  </group>

  <group if="$(eval arg(&quot;mode&quot;) == &quot;odom_imu_gps&quot;)">
    <group if="$(eval arg(&quot;fix_topic&quot;) != &quot;/fix&quot;)">
      <node pkg="topic_tools" type="relay" name="relay_fix"
            args="$(arg fix_topic) /fix"/>
    </group>
    <node pkg="localiza_o_robotica" type="gps_to_odom.py" name="gps_to_odom" output="screen"/>
  </group>

  <group if="$(arg publish_gt)">
    <node pkg="localiza_o_robotica" type="gt_odom_publisher.py" name="gt_odom_publisher" output="screen">
      <param name="model_name" value="$(arg model_name)"/>
    </node>
  </group>

  <group if="$(eval arg(&quot;mode&quot;) == &quot;odom&quot;)">
    <rosparam command="load" ns="ekf_localization" file="$(find localiza_o_robotica)/config/ekf_odom.yaml"/>
  </group>
  <group if="$(eval arg(&quot;mode&quot;) == &quot;odom_imu&quot;)">
    <rosparam command="load" ns="ekf_localization" file="$(find localiza_o_robotica)/config/ekf_odom_imu.yaml"/>
  </group>
  <group if="$(eval arg(&quot;mode&quot;) == &quot;odom_imu_gps&quot;)">
    <rosparam command="load" ns="ekf_localization" file="$(find localiza_o_robotica)/config/ekf_odom_imu_gps.yaml"/>
  </group>

  <node pkg="robot_localization" type="ekf_localization_node" name="ekf_localization" output="screen"/>

  <group if="$(arg record_metrics)">
    <node pkg="localiza_o_robotica" type="localization_metrics.py" name="localization_metrics" output="screen">
      <param name="run_name" value="$(arg mode)"/>
      <param name="output_dir" value="$(arg output_dir)"/>
      <param name="align_gt_origin" value="$(arg align_gt_origin)"/>
      <param name="gt_offset_x" value="$(arg gt_offset_x)"/>
      <param name="gt_offset_y" value="$(arg gt_offset_y)"/>
    </node>
  </group>
</launch>
